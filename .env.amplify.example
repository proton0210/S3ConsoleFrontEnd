# =====================================================================
# Example Environment Variables for AWS Amplify
# Paste these (with real values) into Amplify Console → App settings →
# Environment variables. Real values must NEVER be committed to git.
# =====================================================================

# ---- Public values (safe to ship to the browser) ----
NEXT_PUBLIC_APP_URL=https://s3console.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_public_key
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_public_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---- Server-only (read in route handlers / server components) ----
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key

# Dodo Payments (Phase 1 + 2). Product IDs come from the Dodo dashboard.
# S3CONSOLE_ prefix namespaces these so they don't collide with other
# Dodo-using projects sharing the same Amplify env-var pool.
DODO_API_BASE_URL=https://live.dodopayments.com
S3CONSOLE_DODO_PRODUCT_ID_MONTHLY=pdt_REPLACE_ME
S3CONSOLE_DODO_PRODUCT_ID_YEARLY=pdt_REPLACE_ME
S3CONSOLE_DODO_PRODUCT_ID_LIFETIME=pdt_REPLACE_ME
DODO_RETURN_URL=https://s3console.com/payment-status

# Email config (non-secret display config; API keys are in Secrets Manager).
RESEND_FROM_EMAIL="Vidit <vidit@serverlesscreed.com>"
FOUNDER_NOTIFICATION_EMAIL=vidit@serverlesscreed.com
FOUNDER_DIGEST_MODE=realtime

# AWS region — used by the SDK + Secrets Manager client.
AWS_REGION=ap-south-1
NODE_ENV=production

# ---- Secrets Manager ARNs ----
# Production: paste the ARNs printed by `cdk deploy` (CfnOutputs:
#   ResendSecretArn, DodoApiKeySecretArn, DodoWebhookSecretArn,
#   LicenseSigningSecretArn, ClerkWebhookSecretArn).
# Routes that need credentials read from Secrets Manager via these ARNs.
DODO_API_KEY_SECRET_ARN=arn:aws:secretsmanager:ap-south-1:ACCOUNT:secret:s3console/dodo-api-key-XXXXX
DODO_WEBHOOK_SECRET_ARN=arn:aws:secretsmanager:ap-south-1:ACCOUNT:secret:s3console/dodo-webhook-secret-XXXXX
RESEND_SECRET_ARN=arn:aws:secretsmanager:ap-south-1:ACCOUNT:secret:s3console/resend-api-key-XXXXX
LICENSE_SIGNING_SECRET_ARN=arn:aws:secretsmanager:ap-south-1:ACCOUNT:secret:s3console/license-signing-private-key-XXXXX
CLERK_WEBHOOK_SECRET_ARN=arn:aws:secretsmanager:ap-south-1:ACCOUNT:secret:s3console/clerk-webhook-secret-XXXXX

# ---- LOCAL DEV ONLY (shadow-set when running `npm run dev` on your laptop) ----
# Production reads these from Secrets Manager via the ARNs above; do NOT set
# them in Amplify Console for production environments.
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
RESEND_API_KEY=
CLERK_WEBHOOK_SECRET=

# =====================================================================
# REMOVED in Phase 11 — DO NOT add these back. They shipped AWS root
# credentials to every browser:
#   NEXT_PUBLIC_DYNAMO_ACCESS_KEY_ID    (DELETED)
#   NEXT_PUBLIC_DYNAMO_SECRET_ACCESS_KEY (DELETED)
# DDB access now goes through the Amplify SSR compute role.
#
# Also REMOVED — never were used in production:
#   NEXT_PUBLIC_RAZORPAY_KEY_ID
#   RAZORPAY_KEY_SECRET
#   DODO_ADDITIONAL_LICENSE_PRODUCT_ID  (legacy seat-add, sunset in Phase 11)
# =====================================================================
