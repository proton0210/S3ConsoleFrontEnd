# =====================================================================
# S3Console frontend (Next.js / Amplify)
# Copy this file to .env.local for local dev. Production values are set in
# the Amplify Console — NEVER commit real values to git.
# =====================================================================

# ---- Public values (safe to ship to the browser) ----
NEXT_PUBLIC_APP_URL=https://app.s3console.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
NEXT_PUBLIC_POSTHOG_KEY=phc_REPLACE_ME

# ---- Server-only (read in route handlers / server components) ----
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Dodo Payments (Phase 1 + 2). Product IDs come from the Dodo dashboard.
# S3CONSOLE_ prefix namespaces these so they don't collide with other
# Dodo-using projects sharing the same Amplify env-var pool.
DODO_API_BASE_URL=https://test.dodopayments.com
S3CONSOLE_DODO_PRODUCT_ID_MONTHLY=pdt_REPLACE_ME
S3CONSOLE_DODO_PRODUCT_ID_YEARLY=pdt_REPLACE_ME
S3CONSOLE_DODO_PRODUCT_ID_LIFETIME=pdt_REPLACE_ME
# Team (per-seat yearly) product — used by checkout + /api/team/seats
S3CONSOLE_DODO_PRODUCT_ID_TEAM=pdt_REPLACE_ME

# Backend license API (API Gateway) — used by /api/team/* proxy routes.
# Values come from the CDK stack outputs / API Gateway console.
LICENSE_API_URL=https://xxxx.execute-api.ap-south-1.amazonaws.com/prod
LICENSE_API_KEY=your-api-gateway-key
DODO_RETURN_URL=https://s3console.com/payment-status

# Email (non-secret display config — API keys live in Secrets Manager).
RESEND_FROM_EMAIL="Vidit <vidit@serverlesscreed.com>"
FOUNDER_NOTIFICATION_EMAIL=vidit@serverlesscreed.com
FOUNDER_DIGEST_MODE=realtime

# Secrets Manager ARNs (values fetched at runtime — see Phase 11 CDK setup).
# Local dev: leave blank to fall back to plain env (DODO_API_KEY, etc.) below.
DODO_API_KEY_SECRET_ARN=
DODO_WEBHOOK_SECRET_ARN=
RESEND_SECRET_ARN=
LICENSE_SIGNING_SECRET_ARN=
CLERK_WEBHOOK_SECRET_ARN=

# ---- LOCAL DEV ONLY — production reads from Secrets Manager via ARN above ----
# Do NOT set these in Amplify Console for production.
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
RESEND_API_KEY=
CLERK_WEBHOOK_SECRET=

# AWS region (used by SDK + Secrets Manager client).
AWS_REGION=ap-south-1

# =====================================================================
# REMOVED in Phase 11 — DO NOT add these back. They shipped AWS root
# credentials to every browser:
#   NEXT_PUBLIC_DYNAMO_ACCESS_KEY_ID    (deleted)
#   NEXT_PUBLIC_DYNAMO_SECRET_ACCESS_KEY (deleted)
# DDB access now goes through the Amplify SSR IAM role.
# =====================================================================
